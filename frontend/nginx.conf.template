server {
    listen ${PORT};
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Cache hashed static assets aggressively (vite emits content-hashed names)
    location /assets/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # API → backend service. ${BACKEND_HOST} is "host:port":
    #   local docker-compose: "backend:8000"
    #   Railway:              "<backend-service>.railway.internal:8080"
    location /api/ {
        # Re-resolve the upstream DNS at request time (valid=10s) so a backend
        # redeploy — which rotates its Railway private IP — doesn't strand nginx
        # on a stale cached IP. Requires a variable in proxy_pass to defer
        # resolution; a literal proxy_pass would resolve once at startup.
        resolver ${NGINX_RESOLVER} valid=10s;
        set $upstream_backend ${BACKEND_HOST};
        proxy_pass http://$upstream_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Default 60s isn't enough for /stocks/{symbol}/refresh which can
        # take 60–120s (pipeline + Claude analysis chained synchronously).
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    # SPA fallback — React Router owns client-side routing.
    # `no-cache` forces the browser to revalidate index.html with the server's
    # ETag every navigation, so a fresh deploy is picked up immediately even on
    # browsers (Safari) that otherwise hold index.html in disk cache for hours.
    # The hashed bundles in /assets/ above remain aggressively cached — the
    # filename changes on every build, so cache invalidation is automatic.
    location / {
        add_header Cache-Control "no-cache" always;
        try_files $uri $uri/ /index.html;
    }
}
