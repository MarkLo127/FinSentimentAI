# ============================================================
# FinSentiment AI — Environment Variables Template
# Copy to .env (which is gitignored) and fill in real values.
# ============================================================

# --- PostgreSQL (matches docker-compose.yml defaults) ---
POSTGRES_USER=finsentiment
POSTGRES_PASSWORD=finsentiment_dev
POSTGRES_DB=finsentiment
DATABASE_URL=postgresql+asyncpg://finsentiment:finsentiment_dev@localhost:5433/finsentiment

# --- pgAdmin ---
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin

# --- News API keys (all have free tiers) ---
# https://www.marketaux.com/
MARKETAUX_API_KEY=
# https://finnhub.io/
FINNHUB_API_KEY=
# https://newsapi.org/
NEWSAPI_KEY=
# https://www.alphavantage.co/
ALPHA_VANTAGE_KEY=

# --- Anthropic (Claude Haiku 4.5 for sentiment analysis) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Jina Reader (free 500/min after signup) ---
# https://jina.ai/  →  optional but recommended for higher rate limit
JINA_API_KEY=

# --- JWT auth ---
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Scheduler tuning ---
NEWS_FETCH_INTERVAL_MINUTES=30
SOCIAL_FETCH_INTERVAL_MINUTES=60
DAILY_SUMMARY_HOUR=23
SENTIMENT_ANALYSIS_BATCH_SIZE=10
# Comma-separated tickers the scheduler will poll. Default: just TSM.
# Examples: TSM,AAPL,NVDA,TSLA
MONITORED_TICKERS=TSM

# --- Backend runtime ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
